    "data-patch": ["magento"],
    "email-patterns": ["magento"],
    "email-template": ["magento"],
    "magento-module": ["magento"],
    "module-overview": ["magento"],
    "observer": ["magento"],
    "plugin": ["magento"],
    "rest-api-patterns": ["magento"],
    "layout-diff": ["magento-theme"],
    "create-theme-override": ["magento-theme"],
    "less-theme": ["magento-theme"],
    "react-new-widget": ["magento-react-bridge"],
    "react-dom-hook": ["magento-react-bridge"],
    "react-widget-wiring": ["magento-react-bridge"],
    "react-debug-widget": ["magento-react-bridge"],
    "react-patterns": ["react"],
    "react-a11y-check": ["react"],
    "react-error-handling": ["react"],
    "react-form-wizard": ["react"],
    "react-add-tests": ["react"],
    "react-best-practices": ["react"],
    "react-sync-types": ["graphql", "react"],
