    "magento-react-bridge": "React widgets mounted inside Magento-rendered pages via data attributes",
    "react": "React frontend (any bundler or framework)",
    "graphql": "GraphQL API layer (schema definitions + client operations)",
    "nextjs": "Next.js framework",
    "bigcommerce": "BigCommerce backend/API"
  }
}
